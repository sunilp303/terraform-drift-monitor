# Values referenced by the example workflows — store these as GitHub Actions
# secrets in the caller repo. Never commit a real .env.

# Slack incoming webhook for production drift alerts
# SLACK_WEBHOOK_URL=

# # Optional quieter webhook for non-production environments
# SLACK_WEBHOOK_URL_NONPROD=

# # IAM role assumed via OIDC (output of examples/bootstrap-aws)
# DRIFT_DETECTOR_ROLE_ARN=arn:aws:iam::123456789012:role/gha-drift-detector

# # Audit-trail bucket (output of examples/bootstrap-aws)
# AUDIT_S3_BUCKET=my-org-drift-audit
